# ===========================================
# Memories for Two - Environment Configuration
# ===========================================

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production-min-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=sqlite+aiosqlite:///data/sqlite/memories.db

# CORS - Add your domain when using Cloudflare Tunnel
CORS_ORIGINS=http://localhost:8184,http://127.0.0.1:8184,https://your-domain.com

# File Storage
UPLOAD_DIR=/data/photos
BACKUP_DIR=/data/backups
LOG_DIR=/data/logs

# Max upload size in MB
MAX_UPLOAD_SIZE=50

# Frontend Build
VITE_API_URL=/api

# Cloudflare Tunnel (optional - for production)
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token